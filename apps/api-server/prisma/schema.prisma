generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRoleType {
  SUPER_ADMIN
  ADMIN
  FARMER
  WAREHOUSE
  TRANSPORT
  SELLER
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum VerifyStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ProductStatus {
  DRAFT
  PACKAGED
  STORED
  ORDERED
  IN_TRANSIT
  DELIVERED
  SOLD
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  LOCKED
  RELEASED
  REFUNDED
}

enum DeliveryStatus {
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  ARRIVED
  DELIVERED
  FAILED
}

model Role {
  id          String       @id @default(uuid())
  name        UserRoleType @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users User[]

  @@map("roles")
}

model User {
  id             String       @id @default(uuid())
  fullName       String
  phone          String       @unique
  email          String?      @unique
  passwordHash   String
  roleId         String
  passportSeries String?      @unique
  jshir          String?      @unique
  verifyStatus   VerifyStatus @default(PENDING)
  verifiedAt     DateTime?
  verifiedBy     String?
  status         UserStatus   @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  role        Role          @relation(fields: [roleId], references: [id])
  farmer      Farmer?
  orders      Order[]       @relation("SellerOrders")
  deliveries  Delivery[]    @relation("TransportDeliveries")
  ratings     Rating[]      @relation("UserRatings")
  scanHistory ScanHistory[] @relation("UserScans")

  @@map("users")
}

model Farmer {
  id          String   @id @default(uuid())
  userId      String   @unique
  farmName    String
  region      String
  district    String?
  address     String?
  latitude    Float?
  longitude   Float?
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  products Product[]

  @@map("farmers")
}

model Product {
  id                String        @id @default(uuid())
  farmerId          String
  name              String
  category          String
  description       String?
  quantity          Float
  unit              String
  price             Decimal       @db.Decimal(12, 2)
  status            ProductStatus @default(DRAFT)
  originCountry     String?       @default("Uzbekistan")
  originRegion      String?
  harvestDate       DateTime?
  packagedAt        DateTime?
  storedAt          DateTime?
  warehouseName     String?
  warehouseLocation String?
  shelfCode         String?
  expiresAt         DateTime?
  qrCode            String?       @unique
  batchNumber       String?       @unique
  imageUrl          String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  farmer      Farmer        @relation(fields: [farmerId], references: [id])
  orders      Order[]
  scanHistory ScanHistory[]

  @@map("products")
}

model Order {
  id            String        @id @default(uuid())
  orderNumber   String        @unique
  sellerId      String
  productId     String
  quantity      Float
  unitPrice     Decimal       @db.Decimal(12, 2)
  totalPrice    Decimal       @db.Decimal(12, 2)
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  note          String?
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  seller   User      @relation("SellerOrders", fields: [sellerId], references: [id])
  product  Product   @relation(fields: [productId], references: [id])
  delivery Delivery?
  payment  Payment?
  ratings  Rating[]

  @@map("orders")
}

model Delivery {
  id              String         @id @default(uuid())
  orderId         String         @unique
  transportUserId String?
  status          DeliveryStatus @default(ASSIGNED)
  pickupAddress   String?
  deliveryAddress String
  pickedUpAt      DateTime?
  arrivedAt       DateTime?
  deliveredAt     DateTime?
  failedAt        DateTime?
  failReason      String?
  note            String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order         Order @relation(fields: [orderId], references: [id])
  transportUser User? @relation("TransportDeliveries", fields: [transportUserId], references: [id])

  @@map("deliveries")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  amount        Decimal       @db.Decimal(12, 2)
  status        PaymentStatus @default(UNPAID)
  lockedAt      DateTime?
  releasedAt    DateTime?
  refundedAt    DateTime?
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Rating {
  id               String   @id @default(uuid())
  orderId          String
  fromUserId       String
  toFarmerId       String?
  score            Int
  comment          String?
  blockchainTxHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order    Order @relation(fields: [orderId], references: [id])
  fromUser User  @relation("UserRatings", fields: [fromUserId], references: [id])

  @@map("ratings")
}

model ScanHistory {
  id          String   @id @default(uuid())
  productId   String
  userId      String?
  scannedByIp String?
  userAgent   String?
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User?   @relation("UserScans", fields: [userId], references: [id])

  @@map("scan_history")
}
model Block {
  id        String   @id @default(uuid())
  index     Int      @unique @default(autoincrement())
  hash      String   @unique
  prevHash  String
  data      Json
  timestamp DateTime @default(now())
  nonce     Int      @default(0)
  createdAt DateTime @default(now())

  transactions BlockTransaction[]

  @@map("blocks")
}

model BlockTransaction {
  id         String   @id @default(uuid())
  blockId    String
  type       String
  entityId   String
  entityType String
  fromUserId String?
  toUserId   String?
  data       Json
  hash       String   @unique
  createdAt  DateTime @default(now())

  block Block @relation(fields: [blockId], references: [id])

  @@map("block_transactions")
}